---
import Base from '../../../layouts/Base.astro';
import archives from '../../../data/trending.json';

const posts = archives.en;
---
<Base title="Trending Archive | GitHubCool" description="GitHubCool daily trending article list. Daily posts are archived as date-named pages.">
  <section class="archive">
    <header class="page-header">
      <span class="tag">🔥 Trending</span>
      <h1>Daily Trending Archive</h1>
      <p class="desc">From now on, each daily trending article is archived as an independent page using <code>YYYY-MM-DD</code>.</p>
    </header>

    <div class="list">
      {posts.map((post) => (
        <a class="item" href={post.href}>
          <span class="date">📅 {post.date}</span>
          <h2>{post.title}</h2>
          <p>{post.summary}</p>
          <span class="readmore">Read full article →</span>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .archive { max-width: 860px; margin: 0 auto; }
  .page-header { margin-bottom: 2rem; text-align: center; }
  .page-header h1 { font-size: 2rem; margin: 0.8rem 0; }
  .desc { color: var(--text-muted); }
  .desc code { background: rgba(110,118,129,0.2); padding: 1px 6px; border-radius: 6px; }

  .list { display: flex; flex-direction: column; gap: 1rem; }
  .item {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.25rem 1rem;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }
  .item:hover { border-color: var(--accent); transform: translateY(-2px); }
  .item h2 { color: var(--text); font-size: 1.15rem; margin: 0.4rem 0 0.5rem; line-height: 1.5; }
  .item p { color: var(--text-muted); margin-bottom: 0.5rem; }
  .date { color: var(--accent-orange); font-size: 0.9rem; }
  .readmore { color: var(--accent); font-size: 0.9rem; }

  .tag { display: inline-block; background: rgba(248,81,73,0.15); color: var(--accent-red); padding: 2px 10px; border-radius: 20px; font-size: 0.8rem; }
</style>
